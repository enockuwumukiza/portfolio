# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL via Prisma) ─────────────────────────
# Uncomment when adding a DB
# DATABASE_URL="postgresql://user:password@localhost:5432/portfolio_db?schema=public"

# ── Email (Resend) ────────────────────────────────────────────
# Get free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev
TO_EMAIL=enockuwumukiza850@gmail.com

# ── Auth (for future admin dashboard) ────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
