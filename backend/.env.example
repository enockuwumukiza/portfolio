# ── Backend Environment Variables ───────────────────────────────────────────
# Copy to .env for local development.
# Set all of these in Render dashboard (or Railway) for production.

# Server
NODE_ENV=development
PORT=4000

# PostgreSQL — Render provides this automatically via render.yaml
# For local: use docker-compose (postgres service) or a local Postgres instance
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# Resend (email delivery) — https://resend.com
# Create a free account, get API key from dashboard
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=onboarding@resend.dev
TO_EMAIL=wwwenockuwumukiza@gmail.com

# JWT (for future admin dashboard)
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS whitelist)
# Production: your Vercel URL
FRONTEND_URL=http://localhost:5173
