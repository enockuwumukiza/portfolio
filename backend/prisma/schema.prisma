// Prisma Schema — Portfolio Backend
// Run: npx prisma migrate dev --name init
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Contact messages ──────────────────────────────────────────
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  type      String   @default("general") // collaboration | hiring | general
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ── Analytics events ──────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String   // page_view | project_click | resume_download | etc.
  meta      Json?
  ip        String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  @@map("analytics_events")
}

// ── Guestbook entries ────────────────────────────────────────
model GuestbookEntry {
  id        String   @id @default(cuid())
  name      String
  message   String   @db.Text
  link      String? // optional personal site / GitHub / X profile
  approved  Boolean  @default(true) // flip to false to moderate before showing publicly
  createdAt DateTime @default(now())

  @@map("guestbook_entries")
  @@index([approved, createdAt])
}
