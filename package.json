{
  "name": "enock-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Enock Uwumukiza — Full-Stack Developer Portfolio (monorepo)",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --workspace=frontend run dev",
    "dev:backend": "npm --workspace=backend run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --workspace=frontend run build",
    "build:backend": "npm --workspace=backend run build",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm --workspace=frontend run lint",
    "lint:backend": "npm --workspace=backend run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "install:all": "npm install && npm --workspace=frontend install && npm --workspace=backend install",
    "clean": "rm -rf frontend/node_modules backend/node_modules frontend/dist backend/dist"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.4.2"
  }
}
