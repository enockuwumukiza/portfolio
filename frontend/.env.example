# ── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local development.
# Set these in the Vercel dashboard for production.

# Backend API URL
# Local: http://localhost:4000/api
# Production: https://your-backend.onrender.com/api
VITE_API_URL=http://localhost:4000/api

# Site URL (used in SEO, OG tags)
# Production: https://enockuwumukiza.dev (or your actual domain)
VITE_SITE_URL=http://localhost:5173

# Enable analytics tracking (fires events to /api/analytics/track)
# Set to 'true' in production only
VITE_ENABLE_ANALYTICS=false
